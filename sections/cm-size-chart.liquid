{% schema %}
    {
        "name": "尺寸图",
        "settings": [
            { "type": "text", "id": "title", "label": "标题", "default": "尺寸" },

            { "type": "header","content":"其他"},
            { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_top", "default": 36 },
            { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_bottom", "default": 36 },
            { "type": "text", "id": "custom_class", "label": "自定义class" }
        ],

        "presets": [
            {
                "name": "尺寸图",
                "category": "custom"
            }
        ]
    }
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
    .cm-size-chart-layout .item-title {
        font-size: 28px;
        font-weight: bold;
        margin-bottom: 12px;
    }
    .cm-size-chart-layout .images {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .cm-size-chart-layout .images img {
        max-width: 100%;
        height: auto;
    }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div data-section-id="{{ section.id }}" class="cm-size-chart-layout section-{{ section.id }}-padding">

<div class="cm-size-chart {{ section.settings.custom_class }} {% if section.settings.remove_top_padding %}remove-top-space{% endif %} {% if section.settings.remove_bottom_padding %}remove-bottom-space{% endif %}">

    <div class="mf-container page-width">

        <div class="content-layout">

            <div class="item-title">
                {{ section.settings.title }}
            </div>

            {%- assign dimension_list = product.metafields.custom.dimensions.value -%}
            {% if dimension_list != blank %}
            <div class="images">
                {%- comment -%} 列表型元字段 list.file_reference：遍历 .value；每项对过滤器 image_url，勿再用 .value {%- endcomment -%}
                {% for dimension in dimension_list %}
                  <img
                    src="{{ dimension | image_url: width: 2560 }}"
                    alt="{{ dimension.alt | escape }}"
                    loading="lazy"
                    width="{{ dimension.width }}"
                    height="{{ dimension.height }}"
                  >
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
</div>