{{ 'cm-home-banner.css' | asset_url | stylesheet_tag }}

<section
  id="home-banner-{{ section.id }}"
  class="home-banner home-banner--{{ section.settings.slide_height }} color-{{ section.settings.color_scheme }} gradient"
  data-home-banner
  data-autoplay="{{ section.settings.auto_rotate }}"
  data-delay="{{ section.settings.change_slides_speed | times: 1000 }}"
  data-loop="true"
  aria-label="{{ section.settings.accessibility_info | default: '首页轮播' | escape }}"
>
  <div class="home-banner__swiper swiper">
    <div class="home-banner__wrapper swiper-wrapper">
      {%- for block in section.blocks -%}
        <div
          class="home-banner__slide swiper-slide"
          {{ block.shopify_attributes }}
          role="group"
          aria-label="{{ forloop.index }} / {{ forloop.length }}"
        >
          <div class="home-banner__media{% if block.settings.image == blank %} placeholder{% endif %}">
            {%- if block.settings.image != blank -%}
              {%- liquid
                assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                assign fetch_priority = 'auto'
                if section.index == 1 and forloop.first
                  assign fetch_priority = 'high'
                endif
              -%}
              {%- if forloop.first -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: height: height, sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840', fetchpriority: fetch_priority
                }}
              {%- else -%}
                {{
                  block.settings.image
                  | image_url: width: 3840
                  | image_tag: loading: 'lazy', height: height, sizes: '100vw', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                }}
              {%- endif -%}
            {%- else -%}
              {%- if forloop.index == 1 -%}
                {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            {%- endif -%}
          </div>

          {%- if block.settings.image != blank -%}
            <div
              class="home-banner__slide-overlay"
              style="background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,{{ block.settings.image_overlay_opacity | divided_by: 100.0 | times: 0.3 }}) 100%);"
              aria-hidden="true"
            ></div>
          {%- endif -%}

          <div class="home-banner__content home-banner__content--{{ block.settings.box_align }}">
            <div class="home-banner__box content-container content-container--full-width-mobile">
              {%- if block.settings.heading != blank -%}
                <h2 class="home-banner__heading {{ block.settings.heading_size }}">
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}
              {%- if block.settings.subheading != blank -%}
                <div class="home-banner__text rte">
                  <p>{{ block.settings.subheading }}</p>
                </div>
              {%- endif -%}
              {%- if block.settings.button_label != blank -%}
                <div class="home-banner__buttons">
                  <a
                    {% if block.settings.link != blank %}
                      href="{{ block.settings.link }}"
                    {% else %}
                      role="link" aria-disabled="true"
                    {% endif %}
                    class="button {% if block.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}"
                  >
                    {{ block.settings.button_label | escape }}
                  </a>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button type="button" class="home-banner__nav home-banner__nav--prev" aria-label="上一张"></button>
      <button type="button" class="home-banner__nav home-banner__nav--next" aria-label="下一张"></button>
      <div class="home-banner__pagination swiper-pagination"></div>
    {%- endif -%}
  </div>
</section>

<script>
(function () {
  var sectionId = '{{ section.id }}';
  function initHomeBanner(container) {
    if (typeof Swiper === 'undefined') return;
    var swiperEl = container.querySelector('.home-banner__swiper');
    if (!swiperEl) return;
    var autoplay = container.dataset.autoplay === 'true';
    var delay = parseInt(container.dataset.delay, 10) || 5000;
    var loop = container.dataset.loop !== 'false';
    var slides = container.querySelectorAll('.home-banner__slide');
    if (slides.length === 0) return;
    var paginationEl = container.querySelector('.home-banner__pagination');
    var nextEl = container.querySelector('.home-banner__nav--next');
    var prevEl = container.querySelector('.home-banner__nav--prev');
    var options = {
      loop: loop && slides.length > 1,
      speed: 500,
      grabCursor: true,
      on: { init: function () { container.classList.add('home-banner--initialized'); } }
    };
    if (paginationEl) {
      options.pagination = {
        el: paginationEl,
        clickable: true,
        bulletClass: 'swiper-pagination-bullet',
        bulletActiveClass: 'swiper-pagination-bullet-active'
      };
    }
    if (nextEl && prevEl) { options.navigation = { nextEl: nextEl, prevEl: prevEl }; }
    if (autoplay && slides.length > 1) {
      options.autoplay = { delay: delay, disableOnInteraction: false };
    }
    new Swiper(swiperEl, options);
  }
  function run() {
    var container = document.getElementById('home-banner-' + sectionId);
    if (container && !container.dataset.homeBannerInited) {
      initHomeBanner(container);
      container.dataset.homeBannerInited = 'true';
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
  document.addEventListener('shopify:section:load', function (e) {
    if (e.detail && e.detail.sectionId === sectionId) {
      var container = e.target.querySelector('.home-banner');
      if (container && !container.dataset.homeBannerInited) {
        initHomeBanner(container);
        container.dataset.homeBannerInited = 'true';
      }
    }
  });
})();
</script>

{% schema %}
{
  "name": "首页轮播 Home Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "slide_height",
      "label": "轮播高度",
      "options": [
        { "value": "small", "label": "小" },
        { "value": "medium", "label": "中" },
        { "value": "large", "label": "大" },
        { "value": "full", "label": "满屏" }
      ],
      "default": "full"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "自动轮播",
      "default": true
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "轮播间隔（秒）",
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "配色方案",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "accessibility_info",
      "label": "无障碍描述",
      "default": "首页轮播图"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "幻灯片",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "图片"
        },
        {
          "type": "range",
          "id": "image_overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 10,
          "unit": "%",
          "label": "图片遮罩透明度",
          "default": 0
        },
        {
          "type": "header",
          "content": "文字内容"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "标题",
          "default": "幻灯片标题"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "标题字号",
          "options": [
            { "value": "h2", "label": "小" },
            { "value": "h1", "label": "中" },
            { "value": "h0", "label": "大" }
          ],
          "default": "h1"
        },
        {
          "type": "inline_richtext",
          "id": "subheading",
          "label": "副标题",
          "default": "在这里填写副标题或描述"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "按钮文字"
        },
        {
          "type": "url",
          "id": "link",
          "label": "按钮链接"
        },
        {
          "type": "checkbox",
          "id": "button_style_secondary",
          "label": "使用次要按钮样式",
          "default": false
        },
        {
          "type": "select",
          "id": "box_align",
          "label": "文字位置",
          "options": [
            { "value": "top-left", "label": "左上" },
            { "value": "top-center", "label": "中上" },
            { "value": "top-right", "label": "右上" },
            { "value": "middle-left", "label": "左中" },
            { "value": "middle-center", "label": "居中" },
            { "value": "middle-right", "label": "右中" },
            { "value": "bottom-left", "label": "左下" },
            { "value": "bottom-center", "label": "中下" },
            { "value": "bottom-right", "label": "右下" }
          ],
          "default": "middle-center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "首页轮播 Home Banner",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
