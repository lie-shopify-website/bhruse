{% schema %}
{
  "name": "联系方式 Contact Form",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "textarea", "id": "heading", "label": "标题", "default": "联系我们" },
    { "type": "checkbox", "id": "show_form", "label": "显示表单", "default": true },
    { "type": "textarea", "id": "form_heading", "label": "表单标题", "default": "留言内容" },

    { "type": "header","content":"其他"},
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_top", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "t:sections.all.padding.padding_bottom", "default": 36 },
    { "type": "text", "id": "custom_class", "label": "自定义class" }
  ],
  "blocks": [
    {
      "type": "address",
      "name": "地址",
      "settings": [
        { "type": "image_picker", "id": "company_image", "label": "公司图片" },
        { "type": "textarea", "id": "company_name", "label": "公司名称" },
        { "type": "textarea", "id": "company_address", "label": "公司地址" },
        { "type": "textarea", "id": "company_phone", "label": "公司电话" },
        { "type": "textarea", "id": "company_email", "label": "公司邮箱" },
        { "type": "textarea", "id": "company_website", "label": "公司网站" }
      ]
    },
    {
        "type": "qrcode",
        "name": "二维码",
        "settings": [
            { "type": "image_picker", "id": "qrcode_image", "label": "二维码图片" },
            { "type": "textarea", "id": "info", "label": "二维码信息" },
        ]
    }
  ],
  "presets": [
    {
      "name": "联系方式 Contact Form",
      "category": "Custom"
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{{ 'cm-contact-form.css' | asset_url | stylesheet_tag }}

<section id="contact-form-{{ section.id }}" class="cm-contact-form section-{{ section.id }}-padding">
  <div class="mf-container page-width">
    <div class="contact-form__content">

        <div class="contact-form__locations">
            {%- if section.settings.heading != blank -%}
                <h2 class="contact-form__heading">
                  {{ section.settings.heading }}
                </h2>
            {%- endif -%}
            
            <div class="contact-form__items">
            {%- for block in section.blocks -%}
                {%- if block.type == 'qrcode' -%}
                <div class="contact-form__item qrcode-item">
                    <div class="qrcode-image">
                        {%- if block.settings.qrcode_image != blank -%}
                        <img src="{{ block.settings.qrcode_image | image_url: width: 300 }}" alt="{{ block.settings.qrcode_image.alt }}" width="100%" height="100%">
                        {%- endif -%}
                    </div>
                    <div class="qrcode-info">
                        {%- if block.settings.info != blank -%}
                        <p>{{ block.settings.info }}</p>
                        {%- endif -%}
                    </div>
                </div>
                {%- endif -%}


                {%- if block.type == 'address' -%}
                <div class="contact-form__item">
                    <div class="contact-form__item-image">
                        {%- if block.settings.company_image != blank -%}
                        {%- liquid
                            assign image = block.settings.company_image
                        -%}
                        <picture>
                            <source srcset="{{ image | image_url: width: 989 }}" media="(max-width: 989px)">
                            <source srcset="{{ image | image_url: width: image.width }}" media="(min-width: 990px)">
                            <img
                            src="{{ image | image_url: width: 989 }}"
                            width="100%"
                            height="auto"
                            loading="lazy"
                            alt="{{ image.alt }}"
                            fetchpriority="high"
                            >
                        </picture>
                        {%- endif -%}
                    </div>

                    <div class="contact-form__item-content">
                        {%- if block.settings.company_name != blank -%}
                        <div class="contact-form__item-title">
                            <h3>{{ block.settings.company_name }}</h3>
                        </div>
                        {%- endif -%}
                        {%- if block.settings.company_address != blank -%}
                        <div class="contact-form__item-address with-icon">
                            <span class="icon"><img src="https://cdn.shopify.com/s/files/1/0987/2418/4363/files/address.png?v=1775810263" alt="Location" width="20" height="20"></span>
                            <p>{{ block.settings.company_address }}</p>
                        </div>
                        {%- endif -%}
                        {%- if block.settings.company_phone != blank -%}
                        <div class="contact-form__item-phone with-icon">
                            <span class="icon"><img src="https://cdn.shopify.com/s/files/1/0987/2418/4363/files/phone.png?v=1775810263" alt="Phone" width="20" height="20"></span>
                            {{ block.settings.company_phone }}
                        </div>
                        {%- endif -%}
                        {%- if block.settings.company_email != blank -%}
                        <div class="contact-form__item-email with-icon">
                            <span class="icon"><img src="https://cdn.shopify.com/s/files/1/0987/2418/4363/files/email.png?v=1775810263" alt="Email" width="20" height="20"></span>
                            {{ block.settings.company_email }}
                        </div>
                        {%- endif -%}
                        {%- if block.settings.company_website != blank -%}
                        <div class="contact-form__item-website with-icon">
                            <span class="icon"><img src="https://cdn.shopify.com/s/files/1/0987/2418/4363/files/website.png?v=1775810263" alt="Website" width="20" height="20"></span>
                            {{ block.settings.company_website }}
                        </div>
                        {%- endif -%}
                    </div>
                </div>
                {%- endif -%}
            {%- endfor -%}
            </div>
        </div>

        {%- if section.settings.show_form -%}
        <div class="contact-form__form">

            <div class="contact-form__form-heading">
                {%- if section.settings.form_heading != blank -%}
                <h3 class="contact-form__form-heading">{{ section.settings.form_heading }}</h3>
                {%- endif -%}
            </div>
            <div class="contact-form__form-content">
                {%- liquid
                    assign contact_form_class = 'isolate'
                    if settings.animations_reveal_on_scroll
                      assign contact_form_class = 'isolate scroll-trigger animate--slide-in'
                    endif
                  -%}
                  {%- form 'contact', id: 'ContactForm', class: contact_form_class -%}
                    {%- if form.posted_successfully? -%}
                      <h2 class="form-status form-status-list form__message" tabindex="-1" autofocus>
                        {{- 'icon-success.svg' | inline_asset_content -}}
                        {{ 'templates.contact.form.post_success' | t }}
                      </h2>
                    {%- elsif form.errors -%}
                      <div class="form__message">
                        <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
                          {{- 'icon-error.svg' | inline_asset_content -}}
                          {{ 'templates.contact.form.error_heading' | t }}
                        </h2>
                      </div>
                      <ul class="form-status-list caption-large" role="list">
                        <li>
                          <a href="#ContactForm-email" class="link">
                            {{ form.errors.translated_fields.email | capitalize }}
                            {{ form.errors.messages.email }}
                          </a>
                        </li>
                      </ul>
                    {%- endif -%}
                    <div class="field">
                        <input
                          class="field__input"
                          autocomplete="name"
                          type="text"
                          id="ContactForm-name"
                          name="contact[{{ 'templates.contact.form.name' | t }}]"
                          value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                          placeholder="{{ 'templates.contact.form.name' | t }}"
                        >
                        <label class="field__label" for="ContactForm-name">{{ 'templates.contact.form.name' | t }}</label>
                      </div>
                      <div class="field field--with-error">
                        <input
                          autocomplete="email"
                          type="email"
                          id="ContactForm-email"
                          class="field__input"
                          name="contact[email]"
                          spellcheck="false"
                          autocapitalize="off"
                          value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                          aria-required="true"
                          {% if form.errors contains 'email' %}
                            aria-invalid="true"
                            aria-describedby="ContactForm-email-error"
                          {% endif %}
                          placeholder="{{ 'templates.contact.form.email' | t }}"
                        >
                        <label class="field__label" for="ContactForm-email">
                          {{- 'templates.contact.form.email' | t }}
                          <span aria-hidden="true">*</span></label
                        >
                        {%- if form.errors contains 'email' -%}
                          <small class="contact__field-error" id="ContactForm-email-error">
                            <span class="visually-hidden">{{ 'accessibility.error' | t }}</span>
                            <span class="form__message">
                              <span class="svg-wrapper">
                                {{- 'icon-error.svg' | inline_asset_content -}}
                              </span>
                              {{- form.errors.translated_fields.email | capitalize }}
                              {{ form.errors.messages.email -}}
                            </span>
                          </small>
                        {%- endif -%}
                      </div>
                    <div class="field">
                      <input
                        type="tel"
                        id="ContactForm-phone"
                        class="field__input"
                        autocomplete="tel"
                        name="contact[{{ 'templates.contact.form.phone' | t }}]"
                        pattern="[0-9\-]*"
                        value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                        placeholder="{{ 'templates.contact.form.phone' | t }}"
                      >
                      <label class="field__label" for="ContactForm-phone">{{ 'templates.contact.form.phone' | t }}</label>
                    </div>
                    <div class="field">
                      <textarea
                        rows="10"
                        id="ContactForm-body"
                        class="text-area field__input"
                        name="contact[{{ 'templates.contact.form.comment' | t }}]"
                        placeholder="{{ 'templates.contact.form.comment' | t }}"
                      >
                        {{- form.body -}}
                      </textarea>
                      <label class="form__label field__label" for="ContactForm-body">
                        {{- 'templates.contact.form.comment' | t -}}
                      </label>
                    </div>
                    <div class="contact__button">
                      <button type="submit" class="button">
                        {{ 'templates.contact.form.send' | t }}
                      </button>
                    </div>
                  {%- endform -%}
            </div>
        </div>
        {%- endif -%}
    </div>
  </div>
</section>
